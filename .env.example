# Copy to .env and fill in. Env vars nest with a "__" delimiter (pydantic-settings).

# --- Schwab Trader / Market Data API (OAuth) ---
# Register a "Market Data Production" app at https://developer.schwab.com
# Approval takes a few days; the refresh token expires every 7 days (re-run `wheel-screener auth-login`).
SCHWAB__CLIENT_ID=
SCHWAB__CLIENT_SECRET=
SCHWAB__CALLBACK_URL=https://127.0.0.1:8182
SCHWAB__TOKEN_PATH=.secrets/schwab_token.json

# --- Alpaca (optional alternative chain source) ---  https://alpaca.markets
# Higher rate limit (~1000/min) + key/secret auth (no weekly OAuth). Opt in with CHAIN_SOURCE=alpaca.
# CHAIN_SOURCE=alpaca
# ALPACA__API_KEY=
# ALPACA__API_SECRET=
# ALPACA__FEED=indicative   # free (delayed/modified); "opra" = paid real-time
# ALPACA__TRADING_BASE_URL=https://paper-api.alpaca.markets   # ONLY for paper-account keys (default is live)

# --- Financial Modeling Prep ---  https://site.financialmodelingprep.com
FMP__API_KEY=
FMP__BASE_URL=https://financialmodelingprep.com/stable
# Separate Ultimate-tier key for the ONE-TIME whole-market bulk load (tools/fmp_bulk_import.py).
# Read from this env var, --api-key, or .env. Not needed for normal screening/refresh.
FMP_BULK_API_KEY=

# --- IV rank source: store (roll-your-own SQLite) | orats | flashalpha ---
IV_RANK__SOURCE=store
IV_RANK__DB_PATH=data/iv_history.sqlite
IV_RANK__FLASHALPHA_API_KEY=
IV_RANK__ORATS_TOKEN=

# --- Web app auth (HTTP Basic) ---
# The gate is ENABLED only when AUTH__PASSWORD is set; unset = open (local dev). REQUIRE it in
# production. /health and /static stay open. Caddy adds TLS on top; this is app-level defense.
AUTH__USER=admin
AUTH__PASSWORD=
